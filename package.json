{
  "name": "r2-wallet",
  "version": "0.1.14",
  "description": "Non-custodial wallet for the R-Squared blockchain (r2dex.io).",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/gen-icons.mjs",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "zip": "cd dist && zip -r ../r2-wallet-$npm_package_version.zip .",
    "postinstall": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@r-squared/rsquared-js": "^6.0.9",
    "@r-squared/rsquared-js-ws": "^6.0.2",
    "bignumber.js": "^11.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.31",
    "@eslint/js": "^9.0.0",
    "@types/chrome": "^0.0.325",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "sharp": "^0.34.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.0.0",
    "vite-plugin-node-polyfills": "^0.22.0"
  }
}
