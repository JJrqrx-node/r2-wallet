# Absolute URL for the account registrar endpoint (CORS-open, no WIF involved)
VITE_REGISTRAR_URL=https://r2dex.io/api/register

# Default WSS node. Override to point at a specific node for testing.
VITE_DEFAULT_WSS_NODE=wss://node01.rsquared.digital:8090

# Shared key sent as X-Extension-Key to the registrar so it skips Turnstile.
# Must match EXTENSION_KEY in the r2dex.io Vercel project. Not a secret — it
# ships inside the extension bundle; abuse protection is the per-IP rate limit.
VITE_EXTENSION_KEY=
